# API under test: app.py
FLASK_ENV=development
PORT=5000
HOST=0.0.0.0

# Dashboard: dashboard.py
DASHBOARD_PORT=5050

# OpenAI analysis
# Required for Real AI mode in dashboard and GitHub Actions.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-mini

# GitHub Actions log fetch mode in dashboard
# Required only if you want the dashboard to fetch the latest failed workflow run.
GITHUB_TOKEN=your-github-token
GITHUB_REPOSITORY=owner/repo

# Demo production/config failure
# app_broken_main.py intentionally fails when DB_HOST is missing.
DB_HOST=localhost

